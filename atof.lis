    15                                  ; //****************************************************************************************************************************
    16                                  ; //=======1=========2=========3=========4=========5=========6=========7=========8=========9=========0=========1=========2=========3**//
    17                                  
    18                                  ; //Author information
    19                                  ; //  Author name: Timothy Vu
    20                                  ; //  Author email: timothy.vu@csu.fullerton.edu
    21                                  ; //  Author Section: M/W 2:00pm-3:50pm
    22                                  ; //
    23                                  ; //Program information
    24                                  ; //  Program name: stringtof
    25                                  ; //  Programming languages: seven modules in X86
    26                                  ; //  Date program began: 2022 October 23
    27                                  ; //  Date of last update: 2022 October 26
    28                                  ; //  Date of reorganization of comments: 2022 October 27
    29                                  ; //  Files in this program: _start.asm, _math.asm, cosine.asm, ftoa.asm, itoa.asm, stringtof.asm strlen.asm
    30                                  ; //  Status: Finished.  The program was tested extensively with no errors in Tuffix 2020 Edition.
    31                                  ; //
    32                                  ; //Purpose
    33                                  ; //  The purpose of this file is to receive a char array, convert that array into a float number, and
    34                                  ; //  return the result as a float number (xmm)
    35                                  ; //
    36                                  ; //This file
    37                                  ; //   File name: stringtof.asm
    38                                  ; //   Language: x86
    39                                  ; //   Max page width: 139 columns
    40                                  ; //   Compile: nasm -f elf64 -o stringtof.o -l stringtof.lis stringtof.asm
    41                                  ; //   Linker: ld -o final.out _start.o strlen.o cosine.o itoa.o _math.o ftoa.o stringtof.o 
    42                                  ; //
    43                                  ; //=======1=========2=========3=========4=========5=========6=========7=========8=========9=========0=========1=========2=========3**
    44                                  ; //
    45                                  ; //
    46                                  ; //===== Begin code area ===========================================================================================================
    47                                  
    48                                  ;Assembler directives
    49                                  base_number equ 10                          ;10 base of the decimal number system
    50                                  ascii_zero equ 48                           ;48 is the ascii value of '0'
    51                                  null equ 0
    52                                  minus equ '-'
    53                                  decimal_point equ '.'                       ; <<< THIS IS THE CORRECTED LINE
    54                                  
    55                                  ;Global declaration for linking files.
    56                                  global stringtof                            ;This makes atolong callable by functions outside of this file.
    57                                  
    58                                  segment .data                               ;Place initialized data here
    59                                      ;This segment is empy
    60                                  
    61                                  segment .bss                                ;Declare pointers to un-initialized space in this segment.
    62                                      ;This segment is empty
    63                                  
    64                                  ;==============================================================================================================================
    65                                  ;===== Begin the executable code here.
    66                                  ;==============================================================================================================================
    67                                  segment .text                               ;Place executable instructions in this segment.
    68                                  
    69                                  stringtof:                                  ;Entry point.  Execution begins here.
    70                                  
    71                                  ;The next two instructions should be performed at the start of every assembly program.
    72 00000000 55                      push rbp                                    ;This marks the start of a new stack frame belonging to this execution of this function.
    73 00000001 4889E5                  mov  rbp, rsp                               ;rbp holds the address of the start of this new stack frame.
    74                                  ;The following pushes are performed for safety of the data that may already be in the remaining GPRs.
    75                                  ;This backup process is especially important when this module is called by another asm module.  It is less important when called
    76                                  ;called from a C or C++ function.
    77 00000004 53                      push rbx
    78 00000005 51                      push rcx
    79 00000006 52                      push rdx
    80 00000007 57                      push rdi
    81 00000008 56                      push rsi
    82 00000009 4150                    push r8
    83 0000000B 4151                    push r9
    84 0000000D 4152                    push r10
    85 0000000F 4153                    push r11
    86 00000011 4154                    push r12
    87 00000013 4155                    push r13
    88 00000015 4156                    push r14
    89 00000017 4157                    push r15
    90 00000019 9C                      pushf
    91                                  
    92                                  ;Designate the purpose of selected registers: r8, r9, r10
    93 0000001A 4989F8                  mov r8, rdi                             ;Copy the pointer to char data to r8
    94 0000001D 41B900000000            mov r9, 0                               ;r9 = array index
    95 00000023 41BA00000000            mov r10, 0                              ;r10 = long integer; final integer will be here.
    96 00000029 66450F57FF              xorpd xmm15, xmm15                      ; Final answer float
    97                                  
    98                                  ; Checking the first character to see if it's a '+' or '-'
    99                                  ;The first byte in the array may be '+' or '-', which are valid numeric characters.
   100                                  ;We need to check for the presence of a leading sign.
   101 0000002E 4180382B                cmp byte [r8+1*0], '+'                  ;Check for leading plus sign
   102 00000032 7508                    jne next_comparison
   103 00000034 41B901000000            mov r9, 1
   104 0000003A EB18                    jmp begin_loop
   105                                  
   106                                  next_comparison:
   107 0000003C 4180382D                cmp byte [r8+1*0], '-'                  ;Check for leading minus sign
   108 00000040 7512                    jne begin_loop
   109 00000042 41B901000000            mov r9, 1
   110                                  
   111                                  ; we already checked that this is a float (isFloat in asm)
   112                                  ; '1235.23\0'
   113                                  ; 123523 -> integer -> cvtsi2sd into xmm register -> divide by 10 however many decimal places
   114                                  ; count 2 decimal places 123523/10/10 = 1235.23
   115 00000048 41BB00000000            mov r11, 0 ; num_decimal_places
   116 0000004E 41BD00000000            mov r13, 0 ; This represents if we already decimal place (flag: hit_decimal_place)
   117                                  begin_loop:
   118 00000054 43803C0800              cmp byte [r8+1*r9], null                ;Check the termination condition of the loop
   119 00000059 743A                    je loop_finished
   120                                  ; if we reach the decimal point
   121                                        ; move the index forward
   122                                        ; set hit_decimal_place = True
   123 0000005B 43803C082E              cmp byte [r8+1*r9], decimal_point
   124 00000060 741D                    je HasDecimalPoint
   125                                  
   126 00000062 B80A000000              mov rax, base_number
   127 00000067 49F7E2                  mul r10 ; rax = r10 * 10            mul rax,     r10, 1 on the second iteration
   128                                  ; r10 contains 12
   129                                  ; multiply 10 against 12 = 120
   130 0000006A 4989C2                  mov r10, rax ; second iteration r10 contains 1*10
   131                                  
   132                                  ;This is the instuction we want to perform: "add r10, byte [r8+1*r9]".  But the problem is that the
   133                                  ;sizes of operands do not match.  You cannot add a 1-byte number to an 8-byte number.  However, the
   134                                  ;problem can be fixed by using the extension instructions documented on page 77 of the Jorgensen textbook.
   135 0000006D 438A0408                mov al, byte [r8+1*r9]                  ;The 1-byte number has been copied to al (1-byte register)
   136 00000071 6698                    cbw                                     ;The 1-byte number in al has been extended to 2-byte number in ax
   137 00000073 98                      cwde                                    ;The 2-byte number in ax has been extended to 4-byte number in eax
   138 00000074 4898                    cdqe                                    ;The 4-byte number in eax has been extended to 8-byte number in rax
   139                                  
   140                                  ; current char is placed into rax
   141                                  ; 1234.45
   142                                  ; 1234(T)4
   143                                  ; 123445 decimal_place = 2
   144                                  ; '1' - ascii character - 1 + 48 = 49
   145                                  ; '2' - ascii character - 2 + 48
   146                                  ; subtract 48 from the ascii character to get the actual number
   147                                  ;Now addition is possible
   148 00000076 4901C2                  add r10, rax                            ;To students in 240 class: wasn't that simply great fun?
   149                                  ; 10 + 2 = 12
   150 00000079 4983EA30                sub r10, ascii_zero                     ;A declared constant is compatible with various sizes of registers; explained in Jorgensen.
   151                                  
   152 0000007D EB06                    jmp OverHasDecimalPoint
   153                                  HasDecimalPoint:
   154                                  ; set decimal flag to true
   155 0000007F 41BD01000000            mov r13, 1
   156                                  
   157                                  OverHasDecimalPoint:
   158                                  ; check if flag: hit_decimal_place r13 is true
   159                                  ; increment decimal counter
   160 00000085 4983FD01                cmp r13, 1
   161 00000089 7402                    je IncrementDecimalCounter
   162 0000008B EB03                    jmp OverIncrementCounter
   163                                  IncrementDecimalCounter:
   164 0000008D 49FFC3                  inc r11
   165                                  OverIncrementCounter:
   166                                  
   167 00000090 49FFC1                  inc r9
   168 00000093 EBBF                    jmp begin_loop
   169                                  loop_finished:
   170                                  
   171                                  
   172                                  ; 123445 decimal_place = 2 
   173                                  
   174 00000095 F24D0F2AFA              cvtsi2sd xmm15, r10
   175                                  ; From gdb we see that num_decimal_place is always 1 greater
   176                                  ; sub tract 1 from r15 first
   177 0000009A 4983EB01                sub r11, 1
   178                                  ; for i = 0, i < r15, i++:
   179                                  ;     divide xmm15 by 10
   180                                  
   181                                  ; save a 10.0
   182 0000009E B80A000000              mov rax, 10
   183 000000A3 F24C0F2AF0              cvtsi2sd xmm14, rax
   184                                  
   185 000000A8 41BA00000000            mov r10, 0
   186                                  forloop:
   187 000000AE 4D39DA                  cmp r10, r11
   188 000000B1 740A                    je endForLoop
   189 000000B3 F2450F5EFE              divsd xmm15, xmm14
   190 000000B8 49FFC2                  inc r10
   191 000000BB EBF1                    jmp forloop
   192                                  endForLoop:
   193                                  
   194                                  ;Set the computed value to negative if needed
   195 000000BD 4180382D                cmp byte [r8+1*0], minus                ;Check for leading minus sign
   196 000000C1 7503                    jne positive
   197 000000C3 49F7DA                  neg r10                                 ; <<< THIS IS THE LOGIC BUG (should be applied before cvtsi2sd or to xmm15)
   198                                  
   199                                  positive:
   200 000000C6 4C89D0                  mov rax, r10
   201                                  
   202 000000C9 F2410F10C7              movsd xmm0, xmm15
   203                                  ;==================================================================================================================================
   204                                  ;Epilogue: restore data to the values held before this function was called.
   205 000000CE 9D                      popf
   206 000000CF 415F                    pop r15
   207 000000D1 415E                    pop r14
   208 000000D3 415D                    pop r13
   209 000000D5 415C                    pop r12
   210 000000D7 415B                    pop r11
   211 000000D9 415A                    pop r10
   212 000000DB 4159                    pop r9
   213 000000DD 4158                    pop r8
   214 000000DF 5E                      pop rsi
   215 000000E0 5F                      pop rdi
   216 000000E1 5A                      pop rdx
   217 000000E2 59                      pop rcx
   218 000000E3 5B                      pop rbx
   219 000000E4 5D                      pop rbp                                 ;Now the system stack is in the same state it was when this function began execution.
   220 000000E5 C3                      ret                                     ;Pop a qword from the stack into rip, and continue executing..
   221                                  ;========== End of module atol.asm ================================================================================================; //****************************************************************************************************************************
