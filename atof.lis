    14                                  
    15                                  ; //****************************************************************************************************************************
    16                                  ; //=======1=========2=========3=========4=========5=========6=========7=========8=========9=========0=========1=========2=========3**//
    17                                  
    18                                  ; //Author information
    19                                  ; //  Author name: Timothy Vu
    20                                  ; //  Author email: timothy.vu@csu.fullerton.edu
    21                                  ; //  Author Section: M/W 2:00pm-3:50pm
    22                                  ; //
    23                                  ; //Program information
    24                                  ; //  Program name: stringtof
    25                                  ; //  Programming languages: seven modules in X86
    26                                  ; //  Date program began: 2022 October 23
    27                                  ; //  Date of last update: 2022 October 26
    28                                  ; //  Date of reorganization of comments: 2022 October 27
    29                                  ; //  Files in this program: _start.asm, _math.asm, cosine.asm, ftoa.asm, itoa.asm, stringtof.asm strlen.asm
    30                                  ; //  Status: Finished.  The program was tested extensively with no errors in Tuffix 2020 Edition.
    31                                  ; //
    32                                  ; //Purpose
    33                                  ; //  The purpose of this file is to receive a char array, convert that array into a float number, and
    34                                  ; //  return the result as a float number (xmm)
    35                                  ; //
    36                                  ; //This file
    37                                  ; //   File name: stringtof.asm
    38                                  ; //   Language: x86
    39                                  ; //   Max page width: 139 columns
    40                                  ; //   Compile: nasm -f elf64 -o stringtof.o -l stringtof.lis stringtof.asm
    41                                  ; //   Linker: ld -o final.out _start.o strlen.o cosine.o itoa.o _math.o ftoa.o stringtof.o 
    42                                  ; //
    43                                  ; //=======1=========2=========3=========4=========5=========6=========7=========8=========9=========0=========1=========2=========3**
    44                                  ; //
    45                                  ; //
    46                                  ; //===== Begin code area ===========================================================================================================
    47                                  
    48                                  ;Assembler directives
    49                                  base_number equ 10                      ;10 base of the decimal number system
    50                                  ascii_zero equ 48                       ;48 is the ascii value of '0'
    51                                  null equ 0
    52                                  minus equ '-'
    53                                  decimal_point equ '.'
    54                                  
    55                                  ;Global declaration for linking files.
    56                                  global atof                          ;This makes atolong callable by functions outside of this file.
    57                                  
    58                                  segment .data                           ;Place initialized data here
    59                                     ;This segment is empy
    60 00000000 0000000000002440            ten_float   dq 10.0     ; Floating point constant for 10.0
    61 00000008 000000000000F0BF            minus_one   dq -1.0     ; Floating point constant for -1.0
    62                                  
    63                                  segment .bss                            ;Declare pointers to un-initialized space in this segment.
    64                                     ;This segment is empty
    65                                  
    66                                  ;==============================================================================================================================
    67                                  ;===== Begin the executable code here.
    68                                  ;==============================================================================================================================
    69                                  segment .text                           ;Place executable instructions in this segment.
    70                                  
    71                                  atof:                                ;Entry point.  Execution begins here.
    72                                  
    73                                  ;The next two instructions should be performed at the start of every assembly program.
    74 00000000 55                      push rbp                                ;This marks the start of a new stack frame belonging to this execution of this function.
    75 00000001 4889E5                  mov  rbp, rsp                           ;rbp holds the address of the start of this new stack frame.
    76                                  ;The following pushes are performed for safety of the data that may already be in the remaining GPRs.
    77                                  ;This backup process is especially important when this module is called by another asm module.  It is less important when called
    78                                  ;called from a C or C++ function.
    79 00000004 53                      push rbx
    80 00000005 51                      push rcx
    81 00000006 52                      push rdx
    82 00000007 57                      push rdi
    83 00000008 56                      push rsi
    84 00000009 4150                    push r8
    85 0000000B 4151                    push r9
    86 0000000D 4152                    push r10
    87 0000000F 4153                    push r11
    88 00000011 4154                    push r12
    89 00000013 4155                    push r13
    90 00000015 4156                    push r14
    91 00000017 4157                    push r15
    92 00000019 9C                      pushf
    93                                  
    94                                  
    95                                   ; rdi = pointer to the input string
    96 0000001A 4831F6                      xor     rsi, rsi            ; rsi = index into the string, starts at 0
    97 0000001D 4D31E4                      xor     r12, r12            ; r12b will be our neg_flag (0 = positive, 1 = negative)
    98 00000020 660F57C0                    xorpd   xmm0, xmm0          ; xmm0 will hold the integer part of the number
    99 00000024 660F57C9                    xorpd   xmm1, xmm1          ; xmm1 will hold the fractional part of the number
   100                                  
   101                                      ; --- 1. Handle Sign ---
   102 00000028 803C372D                    cmp     byte [rdi + rsi], '-'
   103 0000002C 7508                        jne     check_positive_sign
   104 0000002E 41B401                      mov     r12b, 1             ; Set neg_flag
   105 00000031 48FFC6                      inc     rsi                 ; Move to the next character
   106 00000034 EB09                        jmp     integer_loop_start
   107                                  
   108                                  check_positive_sign:
   109 00000036 803C372B                    cmp     byte [rdi + rsi], '+'
   110 0000003A 7503                        jne     integer_loop_start
   111 0000003C 48FFC6                      inc     rsi                 ; Move to the next character
   112                                  
   113                                      ; --- 2. Process Integer Part ---
   114                                  integer_loop_start:
   115                                      ; Check if the current character is a digit
   116 0000003F 480FB60437                  movzx   rax, byte [rdi + rsi]
   117 00000044 4883F830                    cmp     rax, '0'
   118 00000048 7C21                        jl      handle_decimal_point ; If less than '0', it's not a digit
   119 0000004A 4883F839                    cmp     rax, '9'
   120 0000004E 7F1B                        jg      handle_decimal_point ; If greater than '9', it's not a digit
   121                                  
   122                                      ; It is a digit, so process it
   123                                      ; xmm0 = xmm0 * 10.0
   124 00000050 F20F590425-                 mulsd   xmm0, [ten_float]
   124 00000055 [00000000]         
   125                                  
   126                                      ; Convert char to integer ('5' -> 5)
   127 00000059 4883E830                    sub     rax, '0'
   128                                  
   129                                      ; Convert integer to float and add to our total
   130 0000005D F2480F2AD0                  cvtsi2sd xmm2, rax          ; xmm2 = (double)rax
   131 00000062 F20F58C2                    addsd   xmm0, xmm2          ; xmm0 = xmm0 + new_digit
   132                                  
   133 00000066 48FFC6                      inc     rsi
   134 00000069 EBD4                        jmp     integer_loop_start
   135                                  
   136                                      ; --- 3. Handle Decimal Point ---
   137                                  handle_decimal_point:
   138 0000006B 803C372E                    cmp     byte [rdi + rsi], '.'
   139 0000006F 7543                        jne     combine_parts       ; If not a decimal, we are done parsing
   140 00000071 48FFC6                      inc     rsi                 ; Move past the '.'
   141                                  
   142                                      ; --- 4. Process Fractional Part ---
   143                                      ; Setup for the fractional loop
   144 00000074 49BD-                       mov     r13, ten_float      ; Use memory address of 10.0
   144 00000076 [0000000000000000] 
   145 0000007E F2410F105D00                movsd   xmm3, [r13]         ; xmm3 = divisor, starting at 10.0
   146                                  
   147                                  fractional_loop_start:
   148                                      ; Check if the current character is a digit
   149 00000084 480FB60437                  movzx   rax, byte [rdi + rsi]
   150 00000089 4883F830                    cmp     rax, '0'
   151 0000008D 7C25                        jl      combine_parts       ; Not a digit, finish up
   152 0000008F 4883F839                    cmp     rax, '9'
   153 00000093 7F1F                        jg      combine_parts       ; Not a digit, finish up
   154                                  
   155                                      ; It's a digit, process it
   156 00000095 4883E830                    sub     rax, '0'            ; Convert char to integer
   157 00000099 F2480F2AD0                  cvtsi2sd xmm2, rax          ; Convert integer to float (e.g., 7 -> 7.0)
   158                                  
   159 0000009E F20F5ED3                    divsd   xmm2, xmm3          ; xmm2 = digit / divisor (e.g., 7.0 / 10.0 = 0.7)
   160 000000A2 F20F58CA                    addsd   xmm1, xmm2          ; Add to fractional total
   161                                  
   162 000000A6 F20F591C25-                 mulsd   xmm3, [ten_float]   ; Update divisor for next digit (10 -> 100 -> 1000)
   162 000000AB [00000000]         
   163 000000AF 48FFC6                      inc     rsi
   164 000000B2 EBD0                        jmp     fractional_loop_start
   165                                  
   166                                      ; --- 5. Final Combination ---
   167                                  combine_parts:
   168 000000B4 F20F58C1                    addsd   xmm0, xmm1          ; Final number = integer part + fractional part
   169                                  
   170                                      ; Apply the negative sign if the flag was set
   171 000000B8 4180FC01                    cmp     r12b, 1
   172 000000BC 7509                        jne     epilogue
   173 000000BE F20F590425-                 mulsd   xmm0, [minus_one]   ; Make the number negative
   173 000000C3 [08000000]         
   174                                  
   175                                  
   176                                  epilogue:
   177                                  ;==================================================================================================================================
   178                                  ;Epilogue: restore data to the values held before this function was called.
   179 000000C7 9D                      popf
   180 000000C8 415F                    pop r15
   181 000000CA 415E                    pop r14
   182 000000CC 415D                    pop r13
   183 000000CE 415C                    pop r12
   184 000000D0 415B                    pop r11
   185 000000D2 415A                    pop r10
   186 000000D4 4159                    pop r9
   187 000000D6 4158                    pop r8
   188 000000D8 5E                      pop rsi
   189 000000D9 5F                      pop rdi
   190 000000DA 5A                      pop rdx
   191 000000DB 59                      pop rcx
   192 000000DC 5B                      pop rbx
   193 000000DD 5D                      pop rbp                       ;Now the system stack is in the same state it was when this function began execution.
   194 000000DE C3                      ret                           ;Pop a qword from the stack into rip, and continue executing..
   195                                  ;========== End of module atol.asm ================================================================================================; //****************************************************************************************************************************
