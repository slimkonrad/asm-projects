    29                                  
    30                                  ;Function ftoa information
    31                                  ;  Function name: ftoa, an acronym for Float to Analog.
    32                                  ;  Version number: 1.0
    33                                  ;  Program classification: Library
    34                                  ;  License: GPL3.  The other licesne LGPL3 was intentionally not applied in this case.
    35                                  ;  Programming language: X86
    36                                  ;  Syntax:  Intel
    37                                  ;  Date development started: 2024-Dec-28
    38                                  ;  Date of last update:      2025-Jan-20
    39                                  ;  Assemble instruction: nasm -f elf64 -l ftoa.lis -o ftoa.o ftoa.asm
    40                                  ;  Develop and test platform: Intel Core i7-5820K running Xubuntu 24.04
    41                                  ;  Status: Final release.  The author will provide updates as bug fixes should any bugs occur.
    42                                  ;  Prototype of this function:  char * ftoa(double floatnum);
    43                                  
    44                                  ;Background
    45                                  ;  Floating-point numbers in most modern computers are stored in a format known as IEEE754.  For example, a 
    46                                  ;number like 4.1 appears to humans a two decimal digits.  But the machine does not store a 4 and a 1.  The 
    47                                  ;machine holds a binary representation of the number that is somewhat akin to 4.0999999999.  When a float 
    48                                  ;number 4.1 is passed to the function ftoa, the function is actually receiving 4.099999.  This function 
    49                                  ;ftoa will act on the internal numberic representation given to it.  In the example, the machine has no 
    50                                  ;knowlege of 4.1 but does have 4.099999999.  We will see this reflected in the outputs produced by ftoa.
    51                                  
    52                                  ;Prototype of ftoa:  char * ftoa(double x);
    53                                  ;ftoa may be called from C++, C, or X86.
    54                                  
    55                                  ;Terminology:  Consider the floating point number  385.6291.   The group 385 is called the integral part and 
    56                                  ;the group 6291 is called the fractional part.
    57                                  
    58                                  ;About the string length of the returned C-string.  The programmer or user of ftoa should set the length of
    59                                  ;returned C-string by adjusting the constant string_len declared in the Declaration section below.  A small value
    60                                  ;less than say 5 will not produce meaningful values.  The constant should be re-set to meet the needs of the 
    61                                  ;current user.
    62                                  
    63                                  ;No AI was used in the construction of this library function ftoa.  The source files driver.cpp and ftoa.asm are
    64                                  ;formatted for understandability by beginning students of computer science.
    65                                  ;========1=========2=========3=========4=========5=========6=========7=========8=========9=========0=========1=========2
    66                                  
    67                                  ;===== Begin Code ======================================================================================
    68                                  
    69                                  ;Declarations
    70                                  ascii_zero equ 48
    71                                  ascii_dot equ  46
    72                                  integer_ten equ 10
    73                                  string_len equ 16	;The next programmer should take charge of setting string length
    74                                  null equ 0
    75                                  global ftoa
    76                                  ;extern printf           ;printf was used for debugging; now it can be safely removed
    77                                  
    78                                  
    79                                  segment .data
    80 00000000 54686520737472696E-        numeric_message db "The string at this point is %s",10,0
    80 00000009 672061742074686973-
    80 00000012 20706F696E74206973-
    80 0000001B 2025730A00         
    81 00000020 6F6E6500                   mark db "one",0
    82                                  
    83                                  segment .bss
    84 00000000 <res 10h>                  number_string resb string_len
    85                                  
    86                                  segment .text
    87                                  ftoa:
    88                                  
    89                                  ;Alert: The GPRs and the SSE registers have not been backed up.
    90 00000000 55                      push rbp
    91 00000001 4889E5                      mov  rbp, rsp
    92 00000004 53                          push rbx                
    93 00000005 4154                        push r12
    94 00000007 4155                        push r13
    95 00000009 4156                        push r14
    96 0000000B 4157                        push r15
    97                                      ;
    98                                  ;Copy the passed in float number to xmm8
    99 0000000D F2440F10C0              movsd xmm8,xmm0
   100                                  
   101                                  ;Backup of GPRs was omitted
   102                                  
   103                                  
   104                                  ;=========================================================================
   105                                  ;Determine the sign of the incoming number.  r15 is the sign flag.
   106 00000012 41BF00000000            mov r15,0
   107 00000018 660F57C0                xorpd xmm0,xmm0     ;Create a temporary zero in xmm0
   108 0000001C 66440F2EC0              ucomisd xmm8,xmm0
   109 00000021 7706                    ja continue
   110 00000023 41BF01000000            mov r15,1
   111                                  continue:    ;Now r15=0 if xmm8 >=0.0 and f15=1 if xmm8 <0.0
   112                                  
   113                                  ;Block to replace xmm8 with its absolute value
   114 00000029 660F57C0                xorpd xmm0,xmm0
   115 0000002D F2410F5CC0              subsd xmm0,xmm8
   116 00000032 F2440F5FC0              maxsd xmm8,xmm0
   117                                  ;============================================================================
   118                                  
   119                                  
   120                                  
   121                                  
   122                                  ;Remove the integral part of xmm8 and save that part as an unsigned integer in rax
   123 00000037 66410F3A0BF003          roundsd xmm6,xmm8,3
   124 0000003E F2480F2DC6              cvtsd2si rax,xmm6
   125                                  
   126                                  ;r12 will count the number of digits in the integral part
   127 00000043 4D31E4                  xor r12,r12
   128                                  
   129                                  ;Rename number_string as r13
   130                                  ;mov r13, number_string
   131 00000046 4C8D2D(00000000)        lea r13, [rel number_string]
   132                                  
   133                                  beginleftsideofdot:
   134                                  
   135 0000004D 4983FC0F                cmp r12,string_len-1   ;Check for space available in the string r13
   136 00000051 0F8DCA000000            jge append_null
   137 00000057 4883F800                cmp rax,0       ;If rax == 0 then break out of the loop
   138 0000005B 7411                      je outofloop
   139 0000005D 4899                      cqo
   140 0000005F 41BA0A000000              mov r10,integer_ten
   141 00000065 49F7F2                    div r10        ;integer_ten
   142 00000068 52                        push rdx       ;Push the remainder value
   143 00000069 49FFC4                    inc r12
   144 0000006C EBDF                      jmp beginleftsideofdot
   145                                  outofloop:
   146                                    ;rax is now 0; r12 has counted the number of pushes onto the stack
   147                                  
   148                                    ;Let r14 be the index into the array r13
   149 0000006E 4D31F6                    xor r14,r14
   150                                  
   151                                  
   152                                  
   153                                  ;  ;Begin block of inserted code=============================================================
   154                                  ;If the original number is negative then place a negative sign in the first byte of the array r13
   155 00000071 4983FF00                  cmp r15,0
   156 00000075 740B                      je positive
   157 00000077 41C645002D                mov byte [r13],'-'
   158 0000007C 49FFC6                    inc r14
   159 0000007F 49FFC4                    inc r12       ;<== New insert instruction to execute in the negative case only
   160                                    ;End block of inserted code==================================================================
   161                                  
   162                                  positive:
   163                                  
   164                                    ;Begin loop that transferrs pushed values to the string r13
   165                                  
   166                                  leftsideofdot:
   167 00000082 4983FE10                  cmp r14,string_len
   168 00000086 0F8D95000000              jge append_null
   169 0000008C 4D39E6                    cmp r14,r12
   170 0000008F 7D0D                      jge appenddot
   171 00000091 58                        pop rax              ;The number popped is one of the decimal digits: 0..9
   172 00000092 0430                      add al,ascii_zero                ;48 equals the ascii value of zero
   173 00000094 4388443500                mov byte [r13+r14],al
   174 00000099 49FFC6                    inc r14
   175 0000009C EBE4                    jmp leftsideofdot
   176                                  
   177                                  appenddot:
   178                                  
   179                                  ;Append one dot
   180 0000009E 43C64435002E            mov byte [r13+r14],ascii_dot
   181 000000A4 49FFC6                  inc r14
   182                                  
   183                                  ;Begin block that converts the fractional part of the original float to the array of chars
   184                                  
   185                                  ;Subtract the whole part from the original number leaving only the fractional part in xmm8.
   186 000000A7 F2440F5CC6              subsd xmm8,xmm6
   187                                  
   188                                  ;Establish the constant 10.0 (ten decimal float)
   189 000000AC 41BA0A000000            mov r10,10
   190 000000B2 F24D0F2AD2              cvtsi2sd xmm10,r10          ;xmm10 is the constant 10.0
   191                                  
   192                                  begin_fractional_loop:      ;Loop with many iterations
   193                                  
   194                                  ;If the fractional part is 0.0, it is time to leave this loop.
   195 000000B7 660F57C0                xorpd xmm0,xmm0
   196 000000BB 66440F2EC0              ucomisd xmm8,xmm0
   197 000000C0 742A                    je out_of_loop
   198                                  
   199                                  ;If there is no available space in the destination array r13 then this loop must stop.
   200 000000C2 4983FE0F                cmp r14, string_len-1
   201 000000C6 7D24                    jge out_of_loop
   202                                  
   203 000000C8 F2450F59C2              mulsd xmm8,xmm10
   204 000000CD 66450F3A0BC803          roundsd xmm9,xmm8,3
   205 000000D4 F24D0F2DC9              cvtsd2si r9,xmm9
   206 000000D9 4983C130                add r9,ascii_zero
   207 000000DD 47884C3500              mov [r13+r14],r9b
   208 000000E2 49FFC6                  inc r14
   209 000000E5 F2450F5CC1              subsd xmm8,xmm9         ;<==Remove the whole number part from xmm8
   210                                  
   211 000000EA EBCB                    jmp begin_fractional_loop    ;Bottom of loop with many iterations
   212                                  
   213                                  out_of_loop:
   214                                      ; --- trim trailing zeros from fractional part ---
   215                                  .trim:
   216 000000EC 4983FE00                    cmp r14, 0
   217 000000F0 7418                        je  .maybe_add_zero
   218 000000F2 43807C35FF30                cmp byte [r13 + r14 - 1], '0'
   219 000000F8 7505                        jne .check_dot
   220 000000FA 49FFCE                      dec r14
   221 000000FD EBED                        jmp .trim
   222                                  
   223                                  .check_dot:
   224                                      ; if we stopped on '.', drop it (e.g., "10." -> "10")
   225 000000FF 43807C35FF2E                cmp byte [r13 + r14 - 1], ascii_dot
   226 00000105 7503                        jne .maybe_add_zero
   227 00000107 49FFCE                      dec r14
   228                                  
   229                                  .maybe_add_zero:
   230                                      ; if the last char is a '.', append a single '0' (e.g., "4." -> "4.0")
   231 0000010A 4983FE00                    cmp r14, 0
   232 0000010E 7411                        je  append_null
   233 00000110 43807C35FF2E                cmp byte [r13 + r14 - 1], ascii_dot
   234 00000116 7509                        jne append_null
   235 00000118 43C644350030                mov byte [r13 + r14], ascii_zero
   236 0000011E 49FFC6                      inc r14
   237                                  
   238                                  append_null:   ;Append the null char
   239 00000121 43C644350000            mov byte [r13+r14],null
   240 00000127 49FFC6                  inc r14
   241                                  
   242                                  ;===== Block for debugging =====================================================
   243                                  ;If deemed un-necessary, this block may be removed by a future programmer.
   244                                  ;mov rax,0
   245                                  ;mov rdi, numeric_message
   246                                  ;mov rsi, r13
   247                                  ;call printf
   248                                  
   249 0000012A 4C89E8                  mov rax,r13       ;Send the string back to the driver
   250 0000012D 415F                    pop  r15
   251 0000012F 415E                        pop  r14
   252 00000131 415D                        pop  r13
   253 00000133 415C                        pop  r12
   254 00000135 5B                          pop  rbx
   255 00000136 5D                          pop  rbp
   256 00000137 C3                      ret
   257                                  
   258                                  ;===== End of source code =================================================
